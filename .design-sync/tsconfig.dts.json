{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmitOnError": false,
    "outDir": "../dist/types",
    "baseUrl": "..",
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["../src/components/ui/**/*.tsx", "../src/lib/utils.ts"]
}
